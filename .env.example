# --- SuperChat (source) ---
SUPERCHAT_API_KEY=
SUPERCHAT_BASE_URL=https://api.superchat.com/v1.0

# --- Chatwoot (target, 1:1 real-data import) ---
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=
# Assign the conversation to its agent; create missing agents
# (Chatwoot then sends an invitation mail!)
CHATWOOT_CREATE_AGENTS=true
# JSON file email->access_token so agent messages appear as that agent
CHATWOOT_AGENT_TOKENS_PATH=/app/agent-tokens.json
